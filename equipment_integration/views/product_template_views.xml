<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Product Template Form View Inheritance -->
        <record id="product_template_form_view_inherit" model="ir.ui.view">
            <field name="name">product.template.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='purchase_ok']" position="after">
                    <field name="is_equipment"/>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="Equipment" attrs="{'invisible': [('is_equipment', '=', False)]}">
                        <group>
                            <group>
                                <field name="equipment_id" 
                                       options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="show_create_equipment_btn" invisible="1"/>
                                <button name="action_create_equipment" 
                                        string="Create Equipment" 
                                        type="object" 
                                        class="oe_highlight"
                                        attrs="{'invisible': [('show_create_equipment_btn', '=', False)]}"
                                        icon="fa-plus"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Product Template List View Inheritance -->
        <record id="product_template_tree_view_inherit" model="ir.ui.view">
            <field name="name">product.template.tree.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="is_equipment"/>
                    <field name="equipment_id" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
