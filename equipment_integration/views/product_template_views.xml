<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Product Template Form View Inheritance -->
        <record id="product_template_form_view_inherit" model="ir.ui.view">
            <field name="name">product.template.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='sale_ok']" position="after">
                    <field name="is_equipment" widget="boolean_toggle"/>
                </xpath>
                <xpath expr="//field[@name='is_equipment']" position="after">
                    <field name="equipment_id" 
                           attrs="{'invisible': [('is_equipment', '=', False)], 'required': [('is_equipment', '=', True)]}"
                           options="{'no_create': True}"/>
                </xpath>
                <xpath expr="//field[@name='equipment_id']" position="after">
                    <button name="action_create_equipment" 
                            string="Create Equipment" 
                            type="object" 
                            class="oe_highlight btn-sm"
                            attrs="{'invisible': [('show_create_equipment_btn', '=', False)]}"
                            icon="fa-plus"/>
                </xpath>
            </field>
        </record>

        <!-- Product Template List View Inheritance -->
        <record id="product_template_tree_view_inherit" model="ir.ui.view">
            <field name="name">product.template.tree.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_list_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="is_equipment" widget="boolean_toggle"/>
                    <field name="equipment_id" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
