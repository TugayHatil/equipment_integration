<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Equipment Creation Wizard Form View -->
        <record id="equipment_creation_wizard_form_view" model="ir.ui.view">
            <field name="name">equipment.creation.wizard.form</field>
            <field name="model">equipment.creation.wizard</field>
            <field name="arch" type="xml">
                <form string="Create Equipment">
                    <group>
                        <group>
                            <field name="product_id" readonly="1"/>
                            <field name="product_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="equipment_name"/>
                            <field name="category_id"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_create_equipment" 
                                string="Create Equipment" 
                                type="object" 
                                class="btn-primary"/>
                        <button string="Cancel" 
                                special="cancel" 
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Equipment Creation Wizard Action -->
        <record id="action_equipment_creation_wizard" model="ir.actions.act_window">
            <field name="name">Create Equipment</field>
            <field name="res_model">equipment.creation.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>
    </data>
</odoo>
