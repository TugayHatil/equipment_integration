<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Equipment Creation Wizard Access Rights -->
        <record id="group_equipment_user" model="res.groups">
            <field name="name">Equipment User</field>
            <field name="category_id" ref="base.module_category_maintenance"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Access Rights for Equipment Creation Wizard -->
        <record id="access_equipment_creation_wizard_user" model="ir.model.access">
            <field name="name">Equipment Creation Wizard User</field>
            <field name="model_id" ref="model_equipment_creation_wizard"/>
            <field name="group_id" ref="group_equipment_user"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Admin Access for Equipment Creation Wizard -->
        <record id="access_equipment_creation_wizard_admin" model="ir.model.access">
            <field name="name">Equipment Creation Wizard Admin</field>
            <field name="model_id" ref="model_equipment_creation_wizard"/>
            <field name="group_id" ref="base.group_system"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Give Admin access to Equipment User group -->
        <record id="access_equipment_creation_wizard_admin_extended" model="ir.model.access">
            <field name="name">Equipment Creation Wizard Admin Extended</field>
            <field name="model_id" ref="model_equipment_creation_wizard"/>
            <field name="group_id" ref="base.group_erp_manager"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
